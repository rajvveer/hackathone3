# ============================================================
# CURALINK — Environment Variables Example
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB (required)
MONGODB_URI=mongodb://localhost:27017/curalink
# For Atlas: mongodb+srv://user:password@cluster.mongodb.net/curalink

# ── LLM Provider (choose one) ──────────────────────────────

# Option A: Groq (recommended — fast, free tier available)
# Get key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
LLM_PROVIDER=groq

# Option B: Ollama (local, no API key needed)
# Run: ollama pull llama3
# OLLAMA_URL=http://localhost:11434
# LLM_PROVIDER=ollama

# ── Redis Cache (optional but recommended) ─────────────────

# Option A: Local Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=your_password_if_any

# Option B: Cloud Redis (Upstash — free tier available)
# Get URL at: https://upstash.com
# REDIS_URL=rediss://default:xxxxxxxxxx@xxxx.upstash.io:6380

# ── PubMed API (optional — increases rate limit from 3 to 10 req/sec) ─
# Get key at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=your_ncbi_api_key_here

# ── Frontend ───────────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api

# ── Authentication (Google OAuth) ──────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
JWT_SECRET=your_super_secret_jwt_key_here
